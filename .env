# Ollama / LLM
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL_TEXT=nomic-embed-text
OLLAMA_EMBED_MODEL_IMAGE=clip-text
OLLAMA_CHAT_MODEL=gemma3:4b
OLLAMA_VISION_MODEL=llama3.2-vision

# Qdrant
QDRANT_URL=http://localhost:6333

# Text RAG
TEXT_RAG_COLLECTION_NAME=test

# Image RAG
IMAGE_RAG_COLLECTION_NAME=rag_images
IMAGE_RAG_VECTOR_SIZE=768
IMAGE_RAG_MIN_SCORE_THRESHOLD=0.55

TEXT_RAG_MIN_SCORE_THRESHOLD=0.01

TEXT_RAG_DEFAULT_LIMIT=45

S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=rag-images
S3_REGION=us-east-1
S3_USE_SSL=false
S3_PUBLIC_URL=http://localhost:9000

NODE_ENV=development

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag_db?schema=public
